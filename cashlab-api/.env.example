# ===========================================
# CashLab API — Environment Variables
# ===========================================
# Copy this file to .env and set your values:
#   cp .env.example .env
# ===========================================

# -----------------
# App Settings
# -----------------
APP_NAME=CashLab API
APP_VERSION=1.0.0
DEBUG=true

# -----------------
# Database
# -----------------
# SQLite (Local Development)
# DATABASE_URL=sqlite+aiosqlite:///./cashlab.db

# PostgreSQL (Supabase / Production)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:6543/postgres?prepared_statement_cache_size=0

# -----------------
# JWT Authentication
# -----------------
SECRET_KEY=change-me-to-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------
# CORS
# -----------------
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# -----------------
# Upload de PDFs
# -----------------
MAX_PDF_SIZE_MB=10
UPLOAD_DIR=./uploads

# -----------------
# OpenAI (OCR de prints de transações)
# -----------------
OPENAI_API_KEY=
